{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet restore && dotnet publish MyAccount.Api/MyAccount.Api.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "cd out && dotnet MyAccount.Api.dll",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
