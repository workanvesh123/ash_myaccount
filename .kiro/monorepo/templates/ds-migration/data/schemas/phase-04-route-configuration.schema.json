{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Phase 04 - Route & Access Configuration",
    "description": "Schema for route path extraction, feature flags, guards, and access configuration",
    "type": "object",
    "required": ["component", "routeConfiguration", "metadata"],
    "properties": {
        "component": {
            "type": "object",
            "required": ["name", "selector", "package", "library"],
            "properties": {
                "name": { "type": "string", "minLength": 1 },
                "selector": { "type": "string", "minLength": 1 },
                "package": { "type": "string", "minLength": 1 },
                "library": { "type": "string", "minLength": 1 }
            }
        },
        "routeConfiguration": {
            "type": "object",
            "required": ["routePath", "featureFlags", "guards", "dynamicParams", "allowAnonymous"],
            "properties": {
                "routePath": { "type": "string", "minLength": 1 },
                "routeSource": { "type": "string", "minLength": 1 },
                "routeCode": { "type": "string", "minLength": 1 },
                "featureFlags": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["flag", "source", "code", "description"],
                        "properties": {
                            "flag": { "type": "string", "minLength": 1 },
                            "source": { "type": "string", "minLength": 1 },
                            "code": { "type": "string", "minLength": 1 },
                            "description": { "type": "string" }
                        }
                    }
                },
                "guards": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["name", "source", "code"],
                        "properties": {
                            "name": { "type": "string", "minLength": 1 },
                            "source": { "type": "string", "minLength": 1 },
                            "code": { "type": "string", "minLength": 1 }
                        }
                    }
                },
                "dynamicParams": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["param", "example", "description"],
                        "properties": {
                            "param": { "type": "string", "minLength": 1 },
                            "example": { "type": "string" },
                            "description": { "type": "string" }
                        }
                    }
                },
                "allowAnonymous": { "type": "boolean" },
                "allowAnonymousSource": { "type": "string" },
                "allowAnonymousCode": { "type": "string" }
            }
        },
        "metadata": {
            "type": "object",
            "required": ["analysisDate", "analysisPhase", "toolsExecuted", "filesAnalyzed"],
            "properties": {
                "analysisDate": { "type": "string", "format": "date" },
                "analysisPhase": { "type": "string", "const": "Phase 04 - Route & Access Configuration" },
                "toolsExecuted": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                },
                "filesAnalyzed": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        }
    }
}
