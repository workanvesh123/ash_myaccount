{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Phase 06 - URL Generation & Documentation",
    "description": "Schema for development URL generation and testing guidance",
    "type": "object",
    "required": ["component", "developmentUrls", "testingGuidance", "metadata"],
    "properties": {
        "component": {
            "type": "object",
            "required": ["name", "selector", "package", "library"],
            "properties": {
                "name": { "type": "string", "minLength": 1 },
                "selector": { "type": "string", "minLength": 1 },
                "package": { "type": "string", "minLength": 1 },
                "library": { "type": "string", "minLength": 1 }
            }
        },
        "developmentUrls": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "url",
                    "brand",
                    "language",
                    "subdomain",
                    "productPath",
                    "componentPath",
                    "brandSource",
                    "brandConfigSource",
                    "brandConfigCode",
                    "urlPatternSource",
                    "urlPatternCode",
                    "note"
                ],
                "properties": {
                    "url": { "type": "string", "format": "uri" },
                    "brand": { "type": "string", "minLength": 1 },
                    "language": { "type": "string", "minLength": 2 },
                    "subdomain": { "type": "string", "minLength": 1 },
                    "productPath": { "type": "string", "minLength": 1 },
                    "componentPath": { "type": "string" },
                    "brandSource": { "type": "string", "minLength": 1 },
                    "brandConfigSource": { "type": "string", "minLength": 1 },
                    "brandConfigCode": { "type": "string", "minLength": 1 },
                    "urlPatternSource": { "type": "string", "minLength": 1 },
                    "urlPatternCode": { "type": "string", "minLength": 1 },
                    "note": { "type": "string", "minLength": 1 }
                }
            }
        },
        "testingGuidance": {
            "type": "object",
            "required": ["accessInstructions", "featureFlagRequirements", "visualLocation"],
            "properties": {
                "accessInstructions": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                },
                "featureFlagRequirements": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "visualLocation": { "type": "string", "minLength": 1 }
            }
        },
        "metadata": {
            "type": "object",
            "required": ["analysisDate", "analysisPhase", "steeringFilesReferenced", "filesAnalyzed"],
            "properties": {
                "analysisDate": { "type": "string", "format": "date" },
                "analysisPhase": { "type": "string", "const": "Phase 06 - URL Generation & Documentation" },
                "steeringFilesReferenced": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                },
                "filesAnalyzed": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        }
    }
}
