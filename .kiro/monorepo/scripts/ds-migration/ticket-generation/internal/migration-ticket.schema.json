{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "migration-ticket.json",
    "title": "Design System Migration Ticket",
    "description": "Schema for design system component migration tickets generated by the ticket generator",
    "type": "object",
    "required": ["ticket_info", "design_system_components", "migration_summary"],
    "properties": {
        "ticket_info": {
            "type": "object",
            "description": "Metadata about the migration ticket",
            "required": ["project", "feature", "ticket_id", "generated_at"],
            "properties": {
                "project": {
                    "type": "string",
                    "description": "The project name that this ticket relates to",
                    "examples": ["casino-app", "myaccount", "payments"]
                },
                "feature": {
                    "type": "string",
                    "description": "The feature name within the project",
                    "examples": ["comp-points", "login", "deposit"]
                },
                "ticket_id": {
                    "type": "string",
                    "description": "Unique identifier for this migration ticket",
                    "pattern": "^[a-zA-Z0-9.-]+-migration$",
                    "examples": [
                        "casino-app-comp-points-migration",
                        "cashier-app-account-recovery-migration",
                        "myaccount-app-France-manual-number-select-migration"
                    ]
                },
                "generated_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 timestamp when this ticket was generated"
                }
            },
            "additionalProperties": false
        },
        "design_system_components": {
            "type": "object",
            "description": "Map of design system components found in this feature, keyed by component name",
            "patternProperties": {
                "^[a-z0-9-]+$": {
                    "$ref": "#/$defs/design_system_component"
                }
            },
            "additionalProperties": false
        },
        "migration_summary": {
            "type": "object",
            "description": "Summary statistics for the entire migration",
            "required": ["total_components", "total_occurrences", "affected_files"],
            "properties": {
                "total_components": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Total number of unique design system components in this migration"
                },
                "total_occurrences": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Total number of component occurrences across all files"
                },
                "affected_files": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Total number of files that contain design system components"
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false,
    "$defs": {
        "design_system_component": {
            "type": "object",
            "description": "Information about a specific design system component and its usage",
            "required": ["design_system_info", "feature_occurrences", "project_implementations", "occurrence_stats", "implementation_stats"],
            "properties": {
                "design_system_info": {
                    "type": "object",
                    "description": "Metadata about the design system component",
                    "required": ["name", "storybook_path", "implementation_path", "selector"],
                    "properties": {
                        "name": {
                            "type": "string",
                            "description": "The canonical name of the design system component",
                            "pattern": "^[a-z0-9-]+$",
                            "examples": ["button", "card", "modal"]
                        },
                        "storybook_path": {
                            "type": "string",
                            "description": "Path to the component's Storybook stories relative to workspace root",
                            "examples": ["packages/design-system/storybook-host-app/src/components/button"]
                        },
                        "implementation_path": {
                            "type": "string",
                            "description": "Path to the component's implementation relative to workspace root",
                            "examples": ["packages/design-system/ui/button/src"]
                        },
                        "selector": {
                            "type": "string",
                            "description": "CSS selector or Angular selector for the component",
                            "examples": ["button[ds-button]", "ds-button", ".ds-button"]
                        }
                    },
                    "additionalProperties": false
                },
                "feature_occurrences": {
                    "type": "array",
                    "description": "List of occurrences of this component within the current feature",
                    "items": {
                        "$ref": "#/$defs/feature_occurrence"
                    }
                },
                "project_implementations": {
                    "type": "array",
                    "description": "List of existing implementations of this component across all projects",
                    "items": {
                        "$ref": "#/$defs/project_implementation"
                    }
                },
                "occurrence_stats": {
                    "type": "object",
                    "description": "Statistics about component occurrences in the current feature",
                    "required": ["total_occurrences", "affected_files", "total_lines_affected"],
                    "properties": {
                        "total_occurrences": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Total number of times this component appears in the feature"
                        },
                        "affected_files": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Number of files in the feature that contain this component"
                        },
                        "total_lines_affected": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Total number of lines of code affected by this component"
                        }
                    },
                    "additionalProperties": false
                },
                "implementation_stats": {
                    "type": "object",
                    "description": "Statistics about existing implementations of this component",
                    "required": ["total_projects", "projects_with_implementations", "total_implementation_lines"],
                    "properties": {
                        "total_projects": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Total number of projects that have this component"
                        },
                        "projects_with_implementations": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Number of projects with actual implementation files"
                        },
                        "total_implementation_lines": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Total lines of code in all implementations"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "feature_occurrence": {
            "type": "object",
            "description": "A specific occurrence of a component within a feature",
            "required": ["feature", "file_path", "lines", "project"],
            "properties": {
                "feature": {
                    "type": "string",
                    "description": "The feature name where this occurrence was found",
                    "examples": ["comp-points", "login", "deposit"]
                },
                "file_path": {
                    "type": "string",
                    "description": "Relative path to the file containing the component occurrence",
                    "examples": ["packages/casino/app/src/comp-points/comp-points.template.html"]
                },
                "lines": {
                    "type": "array",
                    "description": "Array of line numbers where the component appears",
                    "items": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "examples": [[83, 84, 85], [42], [10, 11, 12, 13]]
                },
                "project": {
                    "type": "string",
                    "description": "The project name where this occurrence was found",
                    "examples": ["casino-app", "myaccount", "payments"]
                }
            },
            "additionalProperties": false
        },
        "project_implementation": {
            "type": "object",
            "description": "An existing implementation of a component in a project",
            "required": ["component_name", "project", "relative_path", "lines", "score"],
            "properties": {
                "component_name": {
                    "type": "string",
                    "description": "The name of the component being implemented",
                    "pattern": "^[a-z0-9-]+$",
                    "examples": ["button", "card", "modal"]
                },
                "project": {
                    "type": "string",
                    "description": "The project name containing this implementation",
                    "examples": ["casino-app", "cashier-app", "casino-platform-lib"]
                },
                "relative_path": {
                    "type": "string",
                    "description": "Path to the implementation file relative to workspace root",
                    "examples": ["packages/casino/app/src/comp-points/comp-points.template.html"]
                },
                "lines": {
                    "type": "array",
                    "description": "Array of line numbers where the implementation appears",
                    "items": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "examples": [[10], [32], [2]]
                },
                "score": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Complexity or importance score for this implementation"
                }
            },
            "additionalProperties": false
        }
    }
}
